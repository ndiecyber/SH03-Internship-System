generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MENTOR
  INTERN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String           @unique
  emailVerified    DateTime?
  image            String?
  role             UserRole         @default(INTERN)
  password         String?          // For email/password login
  approvalStatus   ApprovalStatus   @default(APPROVED) // APPROVED for ADMIN, PENDING for INTERN/MENTOR
  approvalReason   String?          @db.Text // Reason for rejection if applicable
  rejectedAt       DateTime?        // When the registration was rejected
  approvedAt       DateTime?        // When the registration was approved
  approvedBy       String?          // Admin ID who approved
  accounts         Account[]
  sessions         Session[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Custom Relations
  applications     Application[]
  logbooks         Logbook[]
  mentorRelations  MentorIntern[] @relation("MentorRelation")
  internRelation   MentorIntern?  @relation("InternRelation")
  certificate      Certificate?
  internEvaluation Evaluation?    @relation("InternEvaluation")
  mentorEvaluations Evaluation[]   @relation("MentorEvaluation")
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InternshipProgram {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("published") // draft, published, closed
  period      String?  // e.g. "July - Dec 2026"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  programId String
  status    String   @default("pending") // pending, approved, rejected
  cvUrl     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  program InternshipProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model Logbook {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  activity  String   @db.Text
  progress  Int      @default(0) // 0-100% progress indicator
  status    String   @default("pending") // pending, approved, rejected
  feedback  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MentorIntern {
  id       String @id @default(cuid())
  mentorId String
  internId String @unique

  mentor User @relation("MentorRelation", fields: [mentorId], references: [id], onDelete: Cascade)
  intern User @relation("InternRelation", fields: [internId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id                 String   @id @default(cuid())
  internId           String   @unique
  mentorId           String
  technicalScore     Float    @default(0)
  attitudeScore      Float    @default(0)
  communicationScore Float    @default(0)
  attendanceScore    Float    @default(0)
  finalScore         Float    @default(0)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  intern User @relation("InternEvaluation", fields: [internId], references: [id], onDelete: Cascade)
  mentor User @relation("MentorEvaluation", fields: [mentorId], references: [id], onDelete: Cascade)
}

model Certificate {
  id         String   @id @default(cuid())
  userId     String   @unique
  certNumber String   @unique
  issuedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
